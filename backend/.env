DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fussfree_db
PORT=5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Change this to a long random secret in production!
JWT_SECRET=fussfree_super_secret_jwt_key_change_in_production

# ── Email (SOS Alerts via Nodemailer) ────────────────────────────────────────
# Gmail setup: Google Account → Security → 2-Step Verification ON
#              → App Passwords → generate a 16-char password → paste below
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=FussFree SOS <your_gmail@gmail.com>
